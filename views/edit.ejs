<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>글 수정</title>
    <style>
        /* 전체 기본 스타일 초기화 */
        body {
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
            background-color: #f8f9fa;
            color: #333;
            margin: 0;
            padding: 40px 20px;
            display: flex;
            justify-content: center;
        }

        .container {
            max-width: 800px;
            width: 100%;
            background: #ffffff;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
        }

        /* 상단 미니 네비게이션 */
        .top-nav {
            margin-bottom: 25px;
            font-size: 14px;
        }

        .top-nav a {
            color: #0066cc;
            text-decoration: none;
            font-weight: 500;
        }

        .top-nav a:hover {
            text-decoration: underline;
        }

        .top-nav .sep {
            color: #dee2e6;
            margin: 0 8px;
        }

        h2 {
            font-size: 24px;
            color: #111;
            margin-top: 0;
            margin-bottom: 25px;
            border-bottom: 2px solid #f1f3f5;
            padding-bottom: 12px;
        }

        /* 폼 요소 레이아웃 */
        .form-group {
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group label {
            font-size: 14px;
            font-weight: 600;
            color: #495057;
        }

        /* 입력란 스타일링 */
        input[type="text"], textarea {
            width: 100%;
            box-sizing: border-box; /* 패딩 포함 크기 계산 */
            padding: 12px 14px;
            border: 1px solid #ced4da;
            border-radius: 6px;
            font-size: 15px;
            font-family: inherit;
            color: #212529;
            background-color: #fff;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        /* 포커스 되었을 때 은은한 파란색 테두리 효과 */
        input[type="text"]:focus, textarea:focus {
            outline: none;
            border-color: #80bdff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }

        textarea {
            resize: vertical; /* 세로 크기 조절만 허용 */
            min-height: 200px;
            line-height: 1.6;
        }

        /* 버튼 구역 */
        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #f1f3f5;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: none;
            border-radius: 6px;
            padding: 10px 20px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-submit {
            background-color: #007bff;
            color: #fff;
        }

        .btn-submit:hover {
            background-color: #0056b3;
        }

        .btn-cancel {
            background-color: #f1f3f5;
            color: #495057;
        }

        .btn-cancel:hover {
            background-color: #e9ecef;
            color: #212529;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="top-nav">
        <a href="/">🏠 홈</a>
        <span class="sep">/</span>
        <a href="/board">📋 목록으로</a>
    </div>

    <h2>✏️ 글 수정하기</h2>

    <form action="/board/edit/<%= post.id %>" method="POST">

        <div class="form-group">
            <label id="title-label" for="title">제목</label>
            <input type="text" id="title" name="title" value="<%= post.title %>" required>
        </div>

        <div class="form-group">
            <label id="content-label" for="content">내용</label>
            <textarea id="content" name="content" required><%= post.content %></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-submit">수정완료</button>
            <a href="/board/view/<%= post.id %>" class="btn btn-cancel">취소</a>
        </div>

    </form>
</div>

</body>
</html>