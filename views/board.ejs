<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>고객센터 게시판</title>
    <style>
        /* 전체 기본 스타일 초기화 */
        body {
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
            background-color: #f8f9fa;
            color: #333;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* 상단 헤더 & 네비게이션 바 */
        .header-bar {
            width: 100%;
            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            display: flex;
            justify-content: center;
            border-bottom: 1px solid #eee;
        }

        .header-container {
            max-width: 1000px;
            width: 100%;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-sizing: border-box;
        }

        .logo-area h1 {
            font-size: 22px;
            margin: 0;
            color: #111;
            font-weight: 800;
        }

        .menu-links {
            display: flex;
            gap: 20px;
            margin-top: 10px;
        }

        .menu-links a {
            color: #0066cc;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .menu-links a:hover {
            color: #004499;
            text-decoration: underline;
        }

        /* 메인 컨텐츠 컨테이너 박스 */
        .container {
            max-width: 1000px;
            width: 100%;
            padding: 40px 20px;
            box-sizing: border-box;
        }

        .board-card {
            background: #ffffff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.03);
            border: 1px solid #e9ecef;
        }

        .section-title {
            font-size: 22px;
            font-weight: 700;
            color: #111;
            margin-bottom: 25px;
            border-left: 4px solid #111;
            padding-left: 10px;
            margin-top: 0;
        }

        /* 상단 네비게이션 및 버튼 */
        .nav-links {
            margin-bottom: 25px;
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .btn-write {
            display: inline-block;
            background-color: #111111;
            color: #fff !important;
            padding: 10px 18px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 14px;
            margin-left: auto; /* 우측 정렬 */
            text-decoration: none;
            transition: background-color 0.2s;
        }

        .btn-write:hover {
            background-color: #2b2b2b;
        }

        hr {
            border: 0;
            height: 1px;
            background: #eee;
            margin: 20px 0;
        }

        /* 게시글 목록 영역 */
        .post-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .post-item {
            padding: 18px 8px;
            border-bottom: 1px solid #f1f3f5;
            transition: background-color 0.2s;
        }

        .post-item:hover {
            background-color: #fbfbfc;
        }

        .post-main {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .post-title-box {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .post-title {
            font-size: 16px;
            font-weight: 600;
            color: #1a1a1a;
            text-decoration: none;
        }

        .post-title:hover {
            color: #0066cc;
            text-decoration: underline;
        }

        .post-author {
            font-size: 13px;
            color: #868e96;
            background: #f1f3f5;
            padding: 2px 8px;
            border-radius: 12px;
        }

        /* 수정 / 삭제 링크 버튼화 */
        .action-links {
            display: flex;
            gap: 6px;
            font-size: 13px;
        }

        .action-links a {
            text-decoration: none;
            padding: 4px 8px;
            border-radius: 4px;
            color: #495057;
            background: #f1f3f5;
            transition: all 0.2s;
        }

        .action-links a.edit-btn:hover {
            background: #e9ecef;
            color: #1a1a1a;
        }

        .action-links a.delete-btn:hover {
            background: #fff5f5;
            color: #e03131;
        }

        /* 답글 스타일 전용 */
        .reply-item {
            margin-left: 35px;
            margin-top: 12px;
            padding: 12px 16px;
            background-color: #f8f9fa;
            border-left: 3px solid #0066cc;
            border-radius: 0 6px 6px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .reply-content {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .reply-arrow {
            color: #0066cc;
            font-weight: bold;
        }

        .reply-title {
            font-size: 14px;
            color: #2b2b2b;
            text-decoration: none;
        }

        .reply-title:hover {
            color: #004499;
            text-decoration: underline;
        }

        .reply-author {
            font-size: 12px;
            color: #0066cc;
            background: #e8f4fd;
            padding: 1px 6px;
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div class="header-bar">
        <div class="header-container">
            <div class="logo-area">
                <a href="/" style="text-decoration: none; color: inherit;">
                    <h1>💻 내 쇼핑몰</h1>
                </a>
                <div class="menu-links">
                    <a href="/">상품목록</a>
                    <a href="/cart">장바구니</a>
                    <a href="/board">고객센터</a>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="board-card">
            <h2 class="section-title">🙋‍ 고객센터 게시판</h2>

            <div class="nav-links">
                <span style="font-size: 14px; color: #666;">안전하고 신속하게 답변해 드립니다.</span>
                <a href="/board/new" class="btn-write">✍️ 새 문의글 쓰기</a>
            </div>

            <hr>

            <ul class="post-list">
            <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <% if(!post.parent_id){ %>

                        <li class="post-item">
                            <div class="post-main">
                                <div class="post-title-box">
                                    <a href="/board/view/<%= post.id %>" class="post-title">
                                        <%= post.title %>
                                    </a>
                                    <span class="post-author"><%= post.author %></span>
                                </div>

                                <% if (typeof user !== 'undefined' && user && (user.name === post.author || user.username === 'admin')) { %>
                                    <div class="action-links">
                                        <a href="/board/edit/<%= post.id %>" class="edit-btn">수정</a>
                                        <a href="/board/delete/<%= post.id %>" class="delete-btn" onclick="return confirm('정말로 이 게시글을 삭제하시겠습니까?');">삭제</a>
                                    </div>
                                <% } %>
                            </div>

                            <% if (typeof replies !== 'undefined') { %>
                                <% replies.forEach(reply => { %>
                                    <% if(reply.parent_id == post.id){ %>

                                        <div class="reply-item">
                                            <div class="reply-content">
                                                <span class="reply-arrow">└</span>
                                                <a href="/board/view/<%= reply.id %>" class="reply-title">
                                                    <%= reply.title %>
                                                </a>
                                                <span class="reply-author"><%= reply.author %></span>
                                            </div>

                                            <% if (typeof user !== 'undefined' && user && (user.name === reply.author || user.username === 'admin')) { %>
                                                <div class="action-links">
                                                    <a href="/board/edit/<%= reply.id %>" class="edit-btn">수정</a>
                                                    <a href="/board/delete/<%= reply.id %>" class="delete-btn" onclick="return confirm('정말로 이 답글을 삭제하시겠습니까?');">삭제</a>
                                                </div>
                                            <% } %>
                                        </div>

                                    <% } %>
                                <% }) %>
                            <% } %>
                        </li>

                    <% } %>
                <% }) %>
            <% } else { %>
                <p style="text-align: center; color: #868e96; padding: 30px 0;">작성된 게시글이 없습니다.</p>
            <% } %>
            </ul>
        </div>
    </div>

</body>
</html>