<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title><%= post.title %> - 상세보기</title>
    <style>
        /* 전체 기본 스타일 초기화  */
        body {
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
            background-color: #f8f9fa;
            color: #333;
            margin: 0;
            padding: 40px 20px;
            display: flex;
            justify-content: center;
        }

        .container {
            max-width: 800px;
            width: 100%;
            background: #ffffff;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
        }

        /* 상단 미니 네비게이션 */
        .top-nav {
            margin-bottom: 20px;
            font-size: 14px;
        }

        .top-nav a {
            color: #0066cc;
            text-decoration: none;
            font-weight: 500;
        }

        .top-nav a:hover {
            text-decoration: underline;
        }

        .top-nav .sep {
            color: #dee2e6;
            margin: 0 8px;
        }

        /* 게시글 헤더 영역 */
        .post-header {
            border-bottom: 2px solid #f1f3f5;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

        .post-title {
            font-size: 26px;
            font-weight: 700;
            color: #111;
            margin: 0 0 12px 0;
            line-height: 1.3;
        }

        .post-info {
            display: flex;
            gap: 15px;
            font-size: 13px;
            color: #868e96;
        }

        .info-item strong {
            color: #495057;
        }

        /* 게시글 본문 영역 */
        .post-content {
            font-size: 16px;
            line-height: 1.6;
            color: #212529;
            min-height: 150px;
            white-space: pre-wrap; /* 줄바꿈 유지 */
            padding: 10px 5px;
        }

        /* 하단 관리 버튼 구역 */
        .action-buttons {
            display: flex;
            gap: 8px;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #f1f3f5;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-default { background: #f1f3f5; color: #495057; }
        .btn-default:hover { background: #e9ecef; color: #212529; }

        .btn-primary { background: #007bff; color: #fff; }
        .btn-primary:hover { background: #0056b3; }

        .btn-warning { background: #ffc107; color: #212529; }
        .btn-warning:hover { background: #e0a800; }

        .btn-danger { background: #dc3545; color: #fff; }
        .btn-danger:hover { background: #bd2130; }

        /* 답글 섹션 스타일 */
        .reply-section {
            margin-top: 40px;
        }

        .reply-section h3 {
            font-size: 18px;
            color: #111;
            margin-bottom: 20px;
            border-left: 4px solid #3b5bdb;
            padding-left: 10px;
        }

        .reply-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .reply-card {
            background-color: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            padding: 15px;
        }

        .reply-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            font-size: 13px;
        }

        .reply-author {
            font-weight: 600;
            color: #3b5bdb;
            background: #edf2ff;
            padding: 2px 8px;
            border-radius: 12px;
        }

        .reply-body {
            font-size: 14px;
            color: #333;
            line-height: 1.5;
            white-space: pre-wrap;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="top-nav">
        <a href="/">🏠 홈</a>
        <span class="sep">/</span>
        <a href="/board">📋 목록으로</a>
    </div>

    <div class="post-header">
        <h1 class="post-title"><%= post.title %></h1>
        <div class="post-info">
            <span class="info-item">✍️ <strong>작성자</strong> <%= post.author %></span>
            <% if (post.created_at) { %>
                <span class="info-item">📅 <strong>작성일</strong> <%= post.created_at %></span>
            <% } %>
        </div>
    </div>

    <div class="post-content">
        <%= post.content %>
    </div>

    <div class="action-buttons">
        <a href="/board" class="btn btn-default">목록으로</a>
        <a href="/board/reply/<%= post.id %>" class="btn btn-primary">💬 답글 작성</a>

        <% if (user && (user.name === post.author || user.username === 'admin')) { %>
            <a href="/board/edit/<%= post.id %>" class="btn btn-warning">수정</a>

            <% if (user.username === 'admin' && user.name !== post.author) { %>
                <a href="/board/delete/<%= post.id %>" class="btn btn-danger" onclick="return confirm('[관리자 권한] 이 게시글을 강제로 삭제하시겠습니까?');">삭제</a>
            <% } else { %>
                <a href="/board/delete/<%= post.id %>" class="btn btn-danger" onclick="return confirm('정말로 이 게시글을 삭제하시겠습니까?');">삭제</a>
            <% } %>
        <% } %>
    </div>

    <div class="reply-section">
        <h3>답글 목록</h3>

        <% if (replies && replies.length > 0) { %>
            <div class="reply-list">
                <% replies.forEach(reply => { %>
                    <div class="reply-card">
                        <div class="reply-header">
                            <span class="reply-author">└ <%= reply.author %></span>

                            <% if (user && (user.name === reply.author || user.username === 'admin')) { %>
                                <div style="display:flex; gap:6px;">
                                    <a href="/board/edit/<%= reply.id %>" style="color:#666; text-decoration:none; font-size:12px;">수정</a>

                                    <% if (user.username === 'admin' && user.name !== reply.author) { %>
                                        <a href="/board/delete/<%= reply.id %>" style="color:#dc3545; text-decoration:none; font-size:12px;" onclick="return confirm('[관리자 권한] 이 답글을 강제로 삭제하시겠습니까?');">삭제</a>
                                    <% } else { %>
                                        <a href="/board/delete/<%= reply.id %>" style="color:#dc3545; text-decoration:none; font-size:12px;" onclick="return confirm('정말로 이 답글을 삭제하시겠습니까?');">삭제</a>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                        <div class="reply-body"><%= reply.title %></div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <p style="color: #868e96; font-size: 14px; padding: 10px 5px;">등록된 답글이 없습니다.</p>
        <% } %>
    </div>
</div>

</body>
</html>